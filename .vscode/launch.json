{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "dex_contagion_trader",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/dex_contagion_trader.py",
            "console": "integratedTerminal",
            "args": [
                "--trading-days",
                "3",
                "--epochs",
                "5"
            ]
        }
        {
            "name": "dex_contagion_trader",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "--verbose"
            ]
        }
    ]
}